{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Yuzu Server Dashboard",
      "url": "/d/yuzu-server",
      "type": "link"
    },
    {
      "title": "Yuzu Gateway Dashboard",
      "url": "/d/yuzu-gateway",
      "type": "link"
    }
  ],
  "panels": [
    {
      "title": "Healthy Agents",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "yuzu_fleet_agents_healthy",
          "legendFormat": "Healthy"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "title": "Heartbeats / sec",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "sum(rate(yuzu_heartbeats_received_total[5m]))",
          "legendFormat": "hb/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "title": "Fleet Commands Executed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "yuzu_fleet_commands_executed_total",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "title": "Stale Agents",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "yuzu_agents_connected - yuzu_fleet_agents_healthy",
          "legendFormat": "Stale"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "title": "Agents by OS",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "yuzu_fleet_agents_by_os",
          "legendFormat": "{{os}}"
        }
      ]
    },
    {
      "title": "Agents by Architecture",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "yuzu_fleet_agents_by_arch",
          "legendFormat": "{{arch}}"
        }
      ]
    },
    {
      "title": "Agents by Version",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "yuzu_fleet_agents_by_version",
          "legendFormat": "{{version}}"
        }
      ]
    },
    {
      "title": "Healthy vs Connected Agents",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "yuzu_agents_connected",
          "legendFormat": "Connected"
        },
        {
          "expr": "yuzu_fleet_agents_healthy",
          "legendFormat": "Healthy (heartbeating)"
        }
      ]
    },
    {
      "title": "Heartbeat Rate by Path",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "expr": "rate(yuzu_heartbeats_received_total[5m])",
          "legendFormat": "{{via}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["yuzu", "fleet", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Yuzu Fleet Overview",
  "uid": "yuzu-fleet",
  "version": 1
}
