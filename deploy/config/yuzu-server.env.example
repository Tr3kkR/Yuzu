# Yuzu Server — Environment Variable Configuration
# Copy this file and set values. All variables are optional; defaults shown.
# CLI flags take precedence over environment variables.

# ── Network ──────────────────────────────────────────────────────────
# YUZU_LISTEN_ADDRESS=0.0.0.0:50051      # Agent gRPC listen address
# YUZU_MANAGEMENT_ADDRESS=0.0.0.0:50052  # Management gRPC listen address
# YUZU_WEB_ADDRESS=127.0.0.1             # Web dashboard bind address
# YUZU_WEB_PORT=8080                     # Web dashboard port
# YUZU_MAX_AGENTS=10000                  # Max concurrent agent connections

# ── TLS ──────────────────────────────────────────────────────────────
# YUZU_CERT=                             # PEM server certificate path
# YUZU_KEY=                              # PEM server private key path
# YUZU_CA_CERT=                          # PEM CA cert for mTLS agent verification

# ── HTTPS Dashboard ──────────────────────────────────────────────────
# YUZU_HTTPS=false                       # Enable HTTPS for web dashboard
# YUZU_HTTPS_PORT=8443                   # HTTPS port
# YUZU_HTTPS_CERT=                       # PEM certificate for HTTPS
# YUZU_HTTPS_KEY=                        # PEM private key for HTTPS

# ── Gateway ──────────────────────────────────────────────────────────
# YUZU_GATEWAY_UPSTREAM=                 # Gateway upstream address (empty=disabled)

# ── Authentication ───────────────────────────────────────────────────
# YUZU_CONFIG=                           # Path to yuzu-server.cfg (credentials)

# ── OIDC SSO ─────────────────────────────────────────────────────────
# YUZU_OIDC_ISSUER=                      # OIDC issuer URL
# YUZU_OIDC_CLIENT_ID=                   # OIDC app client ID
# YUZU_OIDC_CLIENT_SECRET=               # OIDC client secret (use env var, not CLI flag)
# YUZU_OIDC_REDIRECT_URI=               # Callback URL (auto-computed if empty)
# YUZU_OIDC_ADMIN_GROUP=                # Entra group ID for admin role mapping

# ── Data Retention ───────────────────────────────────────────────────
# YUZU_RESPONSE_RETENTION_DAYS=90        # Response data retention (days)
# YUZU_AUDIT_RETENTION_DAYS=365          # Audit log retention (days)

# ── NVD CVE Feed ─────────────────────────────────────────────────────
# YUZU_NVD_API_KEY=                      # NVD API key (higher rate limits)
# YUZU_NVD_PROXY=                        # HTTP proxy for NVD API
# YUZU_NVD_SYNC_INTERVAL=4              # Sync interval in hours

# ── Analytics ────────────────────────────────────────────────────────
# YUZU_ANALYTICS_JSONL=                  # Path for JSONL analytics output
# YUZU_CLICKHOUSE_URL=                   # ClickHouse HTTP URL
# YUZU_CLICKHOUSE_DATABASE=yuzu          # ClickHouse database name
# YUZU_CLICKHOUSE_TABLE=yuzu_events      # ClickHouse table name
# YUZU_CLICKHOUSE_USER=                  # ClickHouse username
# YUZU_CLICKHOUSE_PASSWORD=              # ClickHouse password (use env var, not CLI flag)

# ── OTA Updates ──────────────────────────────────────────────────────
# YUZU_UPDATE_DIR=                       # Directory for agent update binaries

# ── Logging ──────────────────────────────────────────────────────────
# YUZU_LOG_LEVEL=info                    # trace|debug|info|warn|error
# YUZU_LOG_FORMAT=text                   # text|json
# YUZU_LOG_FILE=                         # Log file path (enables file logging)
# YUZU_LOG_MAX_SIZE=52428800             # Max log file size in bytes (50MB)
# YUZU_LOG_MAX_FILES=5                   # Max rotated log files to keep

# ── Rate Limiting ────────────────────────────────────────────────────
# YUZU_RATE_LIMIT=100                    # Max API requests/second per IP
# YUZU_LOGIN_RATE_LIMIT=10              # Max login attempts/second per IP
