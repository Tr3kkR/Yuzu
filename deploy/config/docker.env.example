# Yuzu Docker — Environment Variables
# Use with: docker run --env-file docker.env ...
# Or in docker-compose.yml: env_file: [docker.env]

# Server
YUZU_WEB_ADDRESS=0.0.0.0
YUZU_WEB_PORT=8080
YUZU_LISTEN_ADDRESS=0.0.0.0:50054
YUZU_GATEWAY_UPSTREAM=0.0.0.0:50055
YUZU_LOG_LEVEL=info
YUZU_LOG_FORMAT=json

# Agent
# YUZU_SERVER=yuzu-server:50054
# YUZU_ENROLLMENT_TOKEN=

# Secrets (set these, do not commit)
# YUZU_OIDC_CLIENT_SECRET=
# YUZU_CLICKHOUSE_PASSWORD=
