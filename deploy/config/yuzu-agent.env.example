# Yuzu Agent — Environment Variable Configuration
# Copy this file and set values. All variables are optional; defaults shown.
# CLI flags take precedence over environment variables.

# ── Connection ───────────────────────────────────────────────────────
# YUZU_SERVER=localhost:50051            # Server address (host:port)
# YUZU_AGENT_ID=                         # Stable UUID (auto-generated if empty)
# YUZU_ENROLLMENT_TOKEN=                 # Pre-shared enrollment token

# ── Directories ──────────────────────────────────────────────────────
# YUZU_DATA_DIR=                         # Persistent state directory (platform default)
# YUZU_PLUGIN_DIR=                       # Plugin shared library directory

# ── TLS ──────────────────────────────────────────────────────────────
# YUZU_CA_CERT=                          # PEM CA certificate for server verification
# YUZU_CLIENT_CERT=                      # PEM client certificate for mTLS
# YUZU_CLIENT_KEY=                       # PEM client private key for mTLS

# ── Windows Certificate Store ────────────────────────────────────────
# YUZU_CERT_STORE=                       # Windows cert store name (e.g. MY)
# YUZU_CERT_SUBJECT=                     # Subject CN for cert store lookup
# YUZU_CERT_THUMBPRINT=                  # SHA-1 thumbprint for cert store lookup

# ── Behavior ─────────────────────────────────────────────────────────
# YUZU_HEARTBEAT=30                      # Heartbeat interval (seconds)
# YUZU_UPDATE_CHECK_INTERVAL=21600       # OTA update check interval (seconds, 6h)

# ── Logging ──────────────────────────────────────────────────────────
# YUZU_LOG_LEVEL=info                    # trace|debug|info|warn|error
# YUZU_LOG_FORMAT=text                   # text|json
# YUZU_LOG_FILE=                         # Log file path (enables file logging)
# YUZU_LOG_MAX_SIZE=52428800             # Max log file size in bytes (50MB)
# YUZU_LOG_MAX_FILES=5                   # Max rotated log files to keep
