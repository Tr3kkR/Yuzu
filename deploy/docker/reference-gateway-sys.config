%% Gateway sys.config for the secure multi-container reference
%% (docker-compose.reference-gateway.yml, PKI #1289). Plaintext-free: upstream
%% to the `server` service is MUTUAL TLS, the privileged mgmt/command listener
%% (:50063) is MUTUAL TLS (#1314), and the agent listener (:50051) is one-way TLS.
%% grpcbox reads its own {grpcbox, ...} config (the YUZU_GW_* env vars do NOT
%% drive it — #1291), so this is mounted over the release sys.config. Cert paths
%% are the server-generated defaults in the shared /etc/yuzu/certs volume.
%% Production configuration reference — gateway TLS posture
%% (PKI PR5 upstream mutual TLS; PR5c agent-listener one-way TLS).
%%
%% NOT auto-selected by the build: `rebar3 as prod release` uses the base relx
%% {sys_config, "config/sys.config"} unless the prod profile overrides it, and
%% the Docker images MOUNT deploy/docker/gateway-sys.config over the release
%% config at runtime. This file is the canonical, correct reference for the
%% production grpcbox TLS shape — copy it (or mount it) and adjust cert paths.
%%
%% TLS is configured ENTIRELY in the {grpcbox, ...} block below — grpcbox reads
%% its own config at boot and starts the listeners/channels itself. yuzu_gw's
%% `tls`/`tls_enabled` env (set by YUZU_GW_TLS_* in yuzu_gw_app:apply_tls_
%% overrides/0) is ADVISORY ONLY and does not drive grpcbox; an env-substituted
%% sys.config.src that wires YUZU_GW_TLS_* into the grpcbox block is a tracked
%% follow-up. See docs/pki-architecture.md "Gateway TLS".
%%
%% Container env overrides (handled by yuzu_gw_app:apply_env_overrides/0):
%%   YUZU_GW_UPSTREAM_ADDR  — C++ server hostname (default: 127.0.0.1)
%%   YUZU_GW_UPSTREAM_PORT  — C++ server port     (default: 50055)
%%   YUZU_GW_PROMETHEUS_PORT / YUZU_GW_HEALTH_PORT — metrics / health ports
[
    {yuzu_gw, [
        %% Agent-facing gRPC listen address (agents connect here)
        {agent_listen_addr, "0.0.0.0"},
        {agent_listen_port, 50051},

        %% Operator-facing gRPC listen address (dashboard/CLI connects here)
        {mgmt_listen_addr, "0.0.0.0"},
        {mgmt_listen_port, 50063},

        %% Upstream C++ yuzu-server address (GatewayUpstream service port)
        {upstream_addr, "127.0.0.1"},
        {upstream_port, 50055},

        %% Upstream connection pool size
        {upstream_pool_size, 32},

        %% Heartbeat batching interval (ms)
        {heartbeat_batch_interval_ms, 1000},

        %% Default command timeout (seconds)
        {default_command_timeout_s, 300},

        %% Prometheus metrics HTTP port
        {prometheus_port, 9568},

        %% Health/readiness HTTP port
        {health_port, 8081},

        %% Agent telemetry gauge emission interval (ms)
        {telemetry_gauge_interval_ms, 10000},

        %% Circuit breaker settings (upstream connection protection)
        {circuit_breaker_failure_threshold, 5},
        {circuit_breaker_reset_timeout_ms, 10000},
        {circuit_breaker_max_reset_timeout_ms, 300000},

        %% Stream backpressure threshold (message queue length)
        {backpressure_threshold, 1000},

        %% Consistent hash ring: virtual nodes per physical node
        {hash_ring_vnodes, 256}
    ]},

    {grpcbox, [
        %% ── Upstream channel: mutual TLS to the C++ server ──────────────────
        %% `https` selects ssl (grpcbox prepends ALPN h2). verify_peer is
        %% REQUIRED — an ssl client does NOT verify the server otherwise.
        %% certfile/keyfile present the gateway leaf for the server's client-cert
        %% check (the server's gateway-upstream listener requires a client cert
        %% when TLS is on). Paths point at the server-generated default certs in
        %% the shared cert volume; replace with operator certs if you bring your
        %% own. The dialled host MUST match a SAN in the server's cert (OTP
        %% enforces SNI hostname verification under verify_peer). The default
        %% certs carry SANs `localhost`, `IP:127.0.0.1`, `IP:::1`, and the
        %% server's gethostname() — so the "127.0.0.1" below validates against a
        %% default-cert, same-host install. For cross-container dialing use the
        %% server's hostname and set that service's `hostname:` so its SAN matches.
        {client, #{channels => [
            {default_channel, [{https, "server", 50055, [
                {cacertfile, "/etc/yuzu/certs/default-ca.pem"},
                {certfile,   "/etc/yuzu/certs/default-gateway.pem"},
                {keyfile,    "/etc/yuzu/certs/default-gateway.key"},
                {verify, verify_peer},
                %% Chain depth 2 — margin for one intermediate (M2 subordinate CA);
                %% the M1 default CA signs leaves directly.
                {depth, 2},
                %% TLS 1.2 floor — no 1.0/1.1 (matches grpcbox's own server side,
                %% which pins ['tlsv1.2']). Prevents a stale OTP VM from
                %% negotiating a legacy version.
                {versions, ['tlsv1.2']},
                %% Explicit AEAD + PFS cipher whitelist, ECDSA-leaf-aligned (the
                %% gateway/server leaves are EC P-256). Excludes CBC-SHA1 and
                %% non-PFS RSA-kex suites that some OTP default lists still carry.
                {ciphers, ["ECDHE-ECDSA-AES256-GCM-SHA384",
                           "ECDHE-ECDSA-AES128-GCM-SHA256",
                           "ECDHE-ECDSA-CHACHA20-POLY1305"]}
            ]}], #{}}
        ]}},

        %% ── Listeners ──────────────────────────────────────────────────────
        %% Agent listener (:50051): ONE-WAY (server-authenticated) TLS — encrypts
        %% the hop and authenticates the GATEWAY to agents, WITHOUT requiring a
        %% client cert (verify_none + fail_if_no_peer_cert=false). This closes the
        %% plaintext command-fan-out edge while still letting an UNENROLLED agent
        %% bootstrap (it has no client cert until it completes CSR enrollment).
        %% Requires the vendored+patched grpcbox (_checkouts/grpcbox) — stock
        %% grpcbox v0.17.1 hardcodes fail_if_no_peer_cert=true. Agent identity is
        %% app-layer (enrollment token / gateway_observed_peer), NOT transport.
        %% `ssl => true` is mandatory; without it grpcbox silently runs plaintext.
        {servers, [
            #{grpc_opts => #{
                service_protos => [agent_pb],
                services => #{'yuzu.agent.v1.AgentService' => yuzu_gw_agent_service}
            },
            listen_opts => #{port => 50051, ip => {0,0,0,0}},
            transport_opts => #{ssl => true,
                                certfile   => "/etc/yuzu/certs/default-gateway.pem",
                                keyfile    => "/etc/yuzu/certs/default-gateway.key",
                                cacertfile => "/etc/yuzu/certs/default-ca.pem",
                                verify => verify_none,
                                fail_if_no_peer_cert => false}},
            %% Mgmt listener (:50063): the PRIVILEGED operator/command plane.
            %% STRICT mTLS (#1314, HIGH-2). Do NOT use one-way TLS here — that would
            %% encrypt but leave the plane UNAUTHENTICATED (anyone trusting the
            %% gateway cert could push commands to the fleet). By OMITTING verify /
            %% fail_if_no_peer_cert below, the patched grpcbox uses its strict
            %% defaults (verify_peer + fail_if_no_peer_cert=true) so a client MUST
            %% present a CA-issued cert. The C++ server's command-forwarding client
            %% presents its leaf (server.cpp build_gateway_command_credentials), so
            %% mTLS works here without a bootstrap problem — and a container with no
            %% CA-issued cert (e.g. a compromised agent) is rejected at the TLS layer.
            %% NOTE: verify_peer accepts any CA-issued cert, so an ENROLLED agent's
            %% per-agent leaf would also pass; pinning the mgmt peer to the server's
            %% identity is the PKI-ladder follow-up (#1314 residual). This still
            %% closes the far larger hole: the plaintext, no-cert-required plane.
            #{grpc_opts => #{
                service_protos => [management_pb],
                services => #{'yuzu.server.v1.ManagementService' => yuzu_gw_mgmt_service}
            },
            listen_opts => #{port => 50063, ip => {0,0,0,0}},
            transport_opts => #{ssl => true,
                                certfile   => "/etc/yuzu/certs/default-gateway.pem",
                                keyfile    => "/etc/yuzu/certs/default-gateway.key",
                                cacertfile => "/etc/yuzu/certs/default-ca.pem"}}
        ]}
    ]},

    {kernel, [
        {connect_all, false},
        {net_ticktime, 30},
        {logger_level, info},
        {logger, [
            {handler, default, logger_std_h, #{
                level => info,
                formatter => {logger_formatter, #{
                    template => [time, " [", level, "] ", pid, " ", msg, "\n"]
                }}
            }}
        ]}
    ]}
].
