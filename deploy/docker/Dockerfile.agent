# Yuzu Agent — Multi-stage Docker build
# Build:  docker build -t yuzu-agent -f deploy/docker/Dockerfile.agent .
# Run:    docker run --network host yuzu-agent --server localhost:50051 --no-tls

# ── Stage 1: Build ────────────────────────────────────────────────────────
FROM debian:trixie-slim@sha256:109e2c65005bf160609e4ba6acf7783752f8502ad218e298253428690b9eaa4b AS builder

# TRIPLET selects the vcpkg target. Pass --build-arg TRIPLET=arm64-linux for
# arm64; default keeps the historical x64 build path.
ARG TRIPLET=x64-linux

# Base: debian:trixie-slim (Debian 13). gcc-13 13.3.0 ships in main; CDN
# (deb.debian.org) is reliably reachable when Canonical's archive.ubuntu.com /
# ports.ubuntu.com are blocked at the build host's network egress.
RUN apt-get update && apt-get install -y --no-install-recommends \
    cmake ninja-build gcc-13 g++-13 pkg-config make linux-libc-dev \
    curl zip unzip tar git ca-certificates \
    python3-pip python3-venv python3-yaml \
    && update-alternatives --install /usr/bin/gcc gcc /usr/bin/gcc-13 100 \
    && update-alternatives --install /usr/bin/g++ g++ /usr/bin/g++-13 100 \
    && update-alternatives --install /usr/bin/cc  cc  /usr/bin/gcc-13 100 \
    && update-alternatives --install /usr/bin/c++ c++ /usr/bin/g++-13 100 \
    && pip3 install --break-system-packages meson==1.9.2 \
    && rm -rf /var/lib/apt/lists/*

RUN git clone --depth 1 https://github.com/microsoft/vcpkg.git /opt/vcpkg \
    && /opt/vcpkg/bootstrap-vcpkg.sh -disableMetrics
ENV VCPKG_ROOT=/opt/vcpkg

WORKDIR /src
COPY vcpkg.json vcpkg-configuration.json ./
RUN /opt/vcpkg/vcpkg install --triplet ${TRIPLET} --x-manifest-root=.

COPY . .
# LTO is intentionally OFF for the agent: linking the executable across the
# DSO boundary (libyuzu_agent_core.so) plus the static yuzu_proto archive
# triggers Debian binutils 2.43+ undefined-reference errors on protobuf
# type ctors/dtors. The same gcc-13 + binutils on Ubuntu noble swallowed
# the mismatch silently; trixie's binutils is stricter about LTO contract
# at DSO/static-archive boundaries. Server build keeps LTO because its
# yuzu_proto archive is private to its TU set with no DSO crossing. The
# proper fix is to propagate -flto into yuzu_proto's archive build, which
# is a meson refactor out of scope for this PR.
RUN meson setup builddir \
    --native-file meson/native/linux-gcc13.ini \
    --buildtype=release \
    -Dcmake_prefix_path=/src/vcpkg_installed/${TRIPLET} \
    -Dbuild_tests=false \
    -Dbuild_server=false \
    && meson compile -C builddir

# ── Stage 2: Runtime ──────────────────────────────────────────────────────
FROM debian:trixie-slim@sha256:109e2c65005bf160609e4ba6acf7783752f8502ad218e298253428690b9eaa4b

RUN apt-get update && apt-get install -y --no-install-recommends \
    libssl3 libsqlite3-0 ca-certificates bash \
    && rm -rf /var/lib/apt/lists/* \
    && useradd -r -s /usr/sbin/nologin yuzu-agent \
    && mkdir -p /var/lib/yuzu-agent /usr/lib/yuzu/plugins \
    && chown yuzu-agent:yuzu-agent /var/lib/yuzu-agent

COPY --from=builder /src/builddir/agents/core/yuzu-agent /usr/local/bin/
COPY --from=builder /src/builddir/agents/core/libyuzu_agent_core.so /usr/local/lib/
COPY --from=builder /src/builddir/agents/plugins/ /usr/lib/yuzu/plugins/

RUN ldconfig

USER yuzu-agent
WORKDIR /var/lib/yuzu-agent

ENTRYPOINT ["yuzu-agent"]
CMD ["--server", "yuzu-server:50051", "--plugin-dir", "/usr/lib/yuzu/plugins", "--data-dir", "/var/lib/yuzu-agent"]
