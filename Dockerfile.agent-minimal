# Build Yuzu Agent with hardened vuln_scan plugin
# Multi-stage build: compile in Ubuntu with full dev tools, minimal runtime image

FROM ubuntu:24.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    python3 python3-pip python3-venv \
    ninja-build pkg-config \
    gcc g++ git \
    curl zip unzip tar \
    libssl-dev zlib1g-dev \
    && rm -rf /var/lib/apt/lists/*

# Install Meson in virtual environment
RUN python3 -m venv /opt/venv && \
    /opt/venv/bin/pip install --upgrade pip && \
    /opt/venv/bin/pip install meson==1.9.2

# Install CMake (required by Meson for vcpkg)
RUN apt-get update && apt-get install -y cmake && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copy source
COPY . /build/

# Set up vcpkg and build
RUN git init --initial-branch=main && \
    export VCPKG_ROOT=/vcpkg && \
    git clone https://github.com/Microsoft/vcpkg.git $VCPKG_ROOT && \
    cd $VCPKG_ROOT && \
    ./bootstrap-vcpkg.sh && \
    cd /build && \
    export VCPKG_ROOT=/vcpkg && \
    $VCPKG_ROOT/vcpkg install --triplet arm64-linux && \
    /opt/venv/bin/meson setup build-agent \
      --buildtype=release \
      -Dbuild_agent=true \
      -Dbuild_server=false \
      -Dbuild_tests=false \
      -Dcmake_prefix_path=$VCPKG_ROOT/installed/arm64-linux && \
    /opt/venv/bin/meson compile -C build-agent yuzu-agent && \
    /opt/venv/bin/meson compile -C build-agent vuln_scan

# Runtime stage
FROM ubuntu:24.04

RUN apt-get update && apt-get install -y \
    libssl3 ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Copy agent binary and plugins
COPY --from=builder /build/build-agent/agents/core/yuzu-agent /usr/local/bin/yuzu-agent
COPY --from=builder /build/build-agent/agents/plugins/vuln_scan/vuln_scan.so /opt/yuzu/plugins/vuln_scan.so

RUN chmod +x /usr/local/bin/yuzu-agent && \
    mkdir -p /opt/yuzu/plugins && \
    chmod 755 /opt/yuzu/plugins

# Run agent, connecting to server on Docker network
ENTRYPOINT ["/usr/local/bin/yuzu-agent", "--server", "server:50051", "--no-tls"]
