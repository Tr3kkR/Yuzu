{
  "rule_id": "cis-smartscreen-enabled",
  "name": "CIS — Windows Defender SmartScreen enabled (Explorer)",
  "enabled": true,
  "enforcement_mode": "audit",
  "severity": "high",
  "os_target": "windows",
  "scope": "",
  "spark": {
    "type": "registry-change",
    "params": { "hive": "HKLM", "key": "SOFTWARE\\Policies\\Microsoft\\Windows\\System" }
  },
  "assertion": {
    "type": "registry-value-equals",
    "params": {
      "hive": "HKLM",
      "key": "SOFTWARE\\Policies\\Microsoft\\Windows\\System",
      "value_name": "EnableSmartScreen",
      "value_type": "REG_DWORD",
      "expected": "1"
    }
  },
  "remediation": { "type": "alert-only", "params": {} }
}
