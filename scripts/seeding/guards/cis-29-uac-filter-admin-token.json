{
  "rule_id": "cis-uac-filter-admin-token",
  "name": "CIS — UAC Admin Approval Mode for the built-in Administrator",
  "enabled": true,
  "enforcement_mode": "audit",
  "severity": "high",
  "os_target": "windows",
  "scope": "",
  "spark": {
    "type": "registry-change",
    "params": { "hive": "HKLM", "key": "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System" }
  },
  "assertion": {
    "type": "registry-value-equals",
    "params": {
      "hive": "HKLM",
      "key": "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System",
      "value_name": "FilterAdministratorToken",
      "value_type": "REG_DWORD",
      "expected": "1"
    }
  },
  "remediation": { "type": "alert-only", "params": {} }
}
