{
  "rule_id": "cis-null-session-fallback-off",
  "name": "CIS — LocalSystem NULL session fallback disabled",
  "enabled": true,
  "enforcement_mode": "audit",
  "severity": "medium",
  "os_target": "windows",
  "scope": "",
  "spark": {
    "type": "registry-change",
    "params": { "hive": "HKLM", "key": "SYSTEM\\CurrentControlSet\\Control\\Lsa\\MSV1_0" }
  },
  "assertion": {
    "type": "registry-value-equals",
    "params": {
      "hive": "HKLM",
      "key": "SYSTEM\\CurrentControlSet\\Control\\Lsa\\MSV1_0",
      "value_name": "allownullsessionfallback",
      "value_type": "REG_DWORD",
      "expected": "0"
    }
  },
  "remediation": { "type": "alert-only", "params": {} }
}
