{
  "rule_id": "cis-autoplay-nonvolume-disabled",
  "name": "CIS — AutoPlay disabled for non-volume devices",
  "enabled": true,
  "enforcement_mode": "audit",
  "severity": "medium",
  "os_target": "windows",
  "scope": "",
  "spark": {
    "type": "registry-change",
    "params": { "hive": "HKLM", "key": "SOFTWARE\\Policies\\Microsoft\\Windows\\Explorer" }
  },
  "assertion": {
    "type": "registry-value-equals",
    "params": {
      "hive": "HKLM",
      "key": "SOFTWARE\\Policies\\Microsoft\\Windows\\Explorer",
      "value_name": "NoAutoplayfornonVolume",
      "value_type": "REG_DWORD",
      "expected": "1"
    }
  },
  "remediation": { "type": "alert-only", "params": {} }
}
