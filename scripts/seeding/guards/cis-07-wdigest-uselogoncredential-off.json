{
  "rule_id": "cis-wdigest-uselogoncredential-off",
  "name": "CIS — WDigest cleartext credentials disabled",
  "enabled": true,
  "enforcement_mode": "audit",
  "severity": "high",
  "os_target": "windows",
  "scope": "",
  "spark": {
    "type": "registry-change",
    "params": { "hive": "HKLM", "key": "SYSTEM\\CurrentControlSet\\Control\\SecurityProviders\\WDigest" }
  },
  "assertion": {
    "type": "registry-value-equals",
    "params": {
      "hive": "HKLM",
      "key": "SYSTEM\\CurrentControlSet\\Control\\SecurityProviders\\WDigest",
      "value_name": "UseLogonCredential",
      "value_type": "REG_DWORD",
      "expected": "0"
    }
  },
  "remediation": { "type": "alert-only", "params": {} }
}
