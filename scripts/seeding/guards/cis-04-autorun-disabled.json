{
  "rule_id": "cis-autorun-disabled",
  "name": "CIS — AutoRun disabled (NoDriveTypeAutoRun)",
  "enabled": true,
  "enforcement_mode": "audit",
  "severity": "medium",
  "os_target": "windows",
  "scope": "",
  "spark": {
    "type": "registry-change",
    "params": { "hive": "HKLM", "key": "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\Explorer" }
  },
  "assertion": {
    "type": "registry-value-equals",
    "params": {
      "hive": "HKLM",
      "key": "SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\Explorer",
      "value_name": "NoDriveTypeAutoRun",
      "value_type": "REG_DWORD",
      "expected": "255"
    }
  },
  "remediation": { "type": "alert-only", "params": {} }
}
