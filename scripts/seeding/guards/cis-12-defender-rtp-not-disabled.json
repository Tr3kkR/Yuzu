{
  "rule_id": "cis-defender-rtp-not-disabled",
  "name": "CIS — Defender real-time protection not disabled",
  "enabled": true,
  "enforcement_mode": "audit",
  "severity": "high",
  "os_target": "windows",
  "scope": "",
  "spark": {
    "type": "registry-change",
    "params": { "hive": "HKLM", "key": "SOFTWARE\\Policies\\Microsoft\\Windows Defender\\Real-Time Protection" }
  },
  "assertion": {
    "type": "registry-value-equals",
    "params": {
      "hive": "HKLM",
      "key": "SOFTWARE\\Policies\\Microsoft\\Windows Defender\\Real-Time Protection",
      "value_name": "DisableRealtimeMonitoring",
      "value_type": "REG_DWORD",
      "expected": "0"
    }
  },
  "remediation": { "type": "alert-only", "params": {} }
}
