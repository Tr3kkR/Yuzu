{
  "rule_id": "cis-lm-compatibility-level",
  "name": "CIS — LAN Manager auth level: NTLMv2 only, refuse LM & NTLM",
  "enabled": true,
  "enforcement_mode": "audit",
  "severity": "high",
  "os_target": "windows",
  "scope": "",
  "spark": {
    "type": "registry-change",
    "params": { "hive": "HKLM", "key": "SYSTEM\\CurrentControlSet\\Control\\Lsa" }
  },
  "assertion": {
    "type": "registry-value-equals",
    "params": {
      "hive": "HKLM",
      "key": "SYSTEM\\CurrentControlSet\\Control\\Lsa",
      "value_name": "LmCompatibilityLevel",
      "value_type": "REG_DWORD",
      "expected": "5"
    }
  },
  "remediation": { "type": "alert-only", "params": {} }
}
