{
  "rule_id": "cis-defender-pua-protection",
  "name": "CIS — Defender potentially-unwanted-application (PUA) protection",
  "enabled": true,
  "enforcement_mode": "audit",
  "severity": "medium",
  "os_target": "windows",
  "scope": "",
  "spark": {
    "type": "registry-change",
    "params": { "hive": "HKLM", "key": "SOFTWARE\\Policies\\Microsoft\\Windows Defender" }
  },
  "assertion": {
    "type": "registry-value-equals",
    "params": {
      "hive": "HKLM",
      "key": "SOFTWARE\\Policies\\Microsoft\\Windows Defender",
      "value_name": "PUAProtection",
      "value_type": "REG_DWORD",
      "expected": "1"
    }
  },
  "remediation": { "type": "alert-only", "params": {} }
}
