{
  "rule_id": "cis-rdp-encryption-high",
  "name": "CIS — RDP client connection encryption level High",
  "enabled": true,
  "enforcement_mode": "audit",
  "severity": "medium",
  "os_target": "windows",
  "scope": "",
  "spark": {
    "type": "registry-change",
    "params": { "hive": "HKLM", "key": "SOFTWARE\\Policies\\Microsoft\\Windows NT\\Terminal Services" }
  },
  "assertion": {
    "type": "registry-value-equals",
    "params": {
      "hive": "HKLM",
      "key": "SOFTWARE\\Policies\\Microsoft\\Windows NT\\Terminal Services",
      "value_name": "MinEncryptionLevel",
      "value_type": "REG_DWORD",
      "expected": "3"
    }
  },
  "remediation": { "type": "alert-only", "params": {} }
}
