{
  "rule_id": "demo-rdp-disabled-enforce",
  "name": "Demo RDP disabled (enforce)",
  "enabled": true,
  "enforcement_mode": "enforce",
  "severity": "high",
  "os_target": "windows",
  "scope": "",
  "spark": {
    "type": "registry-change",
    "params": { "hive": "HKLM", "key": "SYSTEM\\CurrentControlSet\\Control\\Terminal Server" }
  },
  "assertion": {
    "type": "registry-value-equals",
    "params": {
      "hive": "HKLM",
      "key": "SYSTEM\\CurrentControlSet\\Control\\Terminal Server",
      "value_name": "fDenyTSConnections",
      "value_type": "REG_DWORD",
      "expected": "1"
    }
  },
  "remediation": { "type": "enforce", "params": {} }
}
