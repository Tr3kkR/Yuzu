{
  "rule_id": "cis-winrm-basic-auth-disabled",
  "name": "CIS — WinRM service Basic auth disabled (AllowBasic)",
  "enabled": true,
  "enforcement_mode": "audit",
  "severity": "medium",
  "os_target": "windows",
  "scope": "",
  "spark": {
    "type": "registry-change",
    "params": { "hive": "HKLM", "key": "SOFTWARE\\Policies\\Microsoft\\Windows\\WinRM\\Service" }
  },
  "assertion": {
    "type": "registry-value-equals",
    "params": {
      "hive": "HKLM",
      "key": "SOFTWARE\\Policies\\Microsoft\\Windows\\WinRM\\Service",
      "value_name": "AllowBasic",
      "value_type": "REG_DWORD",
      "expected": "0"
    }
  },
  "remediation": { "type": "alert-only", "params": {} }
}
