{erl_opts, [
    debug_info,
    warnings_as_errors
]}.

{deps, [
    {grpcbox,    {git, "https://github.com/tsloughter/grpcbox.git", {tag, "v0.17.1"}}},
    {gpb,        "4.21.2"},
    {telemetry,  "1.3.0"},
    {prometheus, "4.11.0"},
    {prometheus_httpd, "2.1.2"},
    {recon,      "2.5.5"},
    {gproc,      "1.0.0"}
]}.

{project_plugins, [
    {grpcbox_plugin, {git, "https://github.com/tsloughter/grpcbox_plugin.git", {branch, "master"}}}
]}.

{grpc, [
    {protos, "priv/proto"},
    {gpb_opts, [
        {module_name_suffix, "_pb"},
        {i, "priv/proto"},
        use_packages,
        maps,
        strings_as_binaries,
        {maps_unset_optional, omitted},
        {report_warnings, true},
        {target_erlang_version, 26}
    ]}
]}.

{relx, [
    {release, {yuzu_gw, "0.1.0"}, [
        yuzu_gw,
        sasl
    ]},
    {mode, dev},
    {sys_config, "config/sys.config"},
    {vm_args,    "config/vm.args"},
    {extended_start_script, true}
]}.

{profiles, [
    {prod, [
        {relx, [
            {mode, prod},
            {include_erts, true}
        ]}
    ]},
    {test, [
        {deps, [
            {meck, "0.9.2"},
            {proper, "1.4.0"}
        ]},
        {erl_opts, [debug_info, nowarn_export_all]},
        {ct_opts, [
            {sys_config, "config/sys.config"},
            {verbose, true}
        ]},
        {cover_enabled, true},
        {cover_opts, [verbose]}
    ]}
]}.

%% Common Test configuration
{ct_opts, [
    {logdir, "_build/test/logs"},
    {sys_config, "config/test.config"}
]}.

%% EUnit configuration
{eunit_opts, [
    verbose,
    {report, {eunit_surefire, [{dir, "_build/test/eunit"}]}}
]}.

{shell, [
    {apps, [yuzu_gw]}
]}.
