{erl_opts, [
    debug_info,
    warnings_as_errors,
    {parse_transform, lager_transform}
]}.

{deps, [
    {grpcbox,    {git, "https://github.com/tsloughter/grpcbox.git", {tag, "0.17.1"}}},
    {gpb,        "4.21.2"},
    {telemetry,  "1.3.0"},
    {prometheus, "4.11.0"},
    {recon,      "2.5.5"},
    {gproc,      "1.0.0"}
]}.

{project_plugins, [
    {grpcbox_plugin, {git, "https://github.com/tsloughter/grpcbox_plugin.git", {branch, "main"}}}
]}.

{grpc, [
    {protos, "priv/proto"},
    {gpb_opts, [
        {module_name_suffix, "_pb"},
        {i, "priv/proto"},
        use_packages,
        maps,
        strings_as_binaries,
        {maps_unset_optional, omitted},
        {report_warnings, true},
        {target_erlang_version, 26}
    ]}
]}.

{relx, [
    {release, {yuzu_gw, "0.1.0"}, [
        yuzu_gw,
        sasl
    ]},
    {mode, dev},
    {sys_config, "config/sys.config"},
    {vm_args,    "config/vm.args"},
    {extended_start_script, true}
]}.

{profiles, [
    {prod, [
        {relx, [
            {mode, prod},
            {include_erts, true}
        ]}
    ]},
    {test, [
        {deps, [
            {meck, "0.9.2"},
            {proper, "1.4.0"}
        ]}
    ]}
]}.

{shell, [
    {apps, [yuzu_gw]}
]}.
