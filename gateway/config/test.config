[
    {yuzu_gw, [
        %% Use non-conflicting ports for testing
        {agent_listen_addr, "127.0.0.1"},
        {agent_listen_port, 50151},
        {mgmt_listen_addr, "127.0.0.1"},
        {mgmt_listen_port, 50152},

        %% Mock upstream (tests will mock grpcbox_client)
        {upstream_addr, "127.0.0.1"},
        {upstream_port, 59999},
        {upstream_pool_size, 2},

        %% Fast intervals for testing
        {heartbeat_batch_interval_ms, 100},
        {default_command_timeout_s, 5},
        {telemetry_gauge_interval_ms, 60000},

        %% Reduced for testing
        {hash_ring_vnodes, 16}
    ]},

    {grpcbox, [
        {client, #{channels => [
            {default_channel, [{http, "127.0.0.1", 59999, []}], #{}}
        ]}}
    ]},

    {kernel, [
        {logger_level, warning},
        {logger, [
            {handler, default, logger_std_h, #{
                level => warning,
                formatter => {logger_formatter, #{
                    template => [time, " [", level, "] ", msg, "\n"]
                }}
            }}
        ]}
    ]}
].
