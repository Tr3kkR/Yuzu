[
    {yuzu_gw, [
        %% Agent-facing gRPC listen address (agents connect here)
        {agent_listen_addr, "0.0.0.0"},
        {agent_listen_port, 50061},

        %% Operator-facing gRPC listen address (dashboard/CLI connects here)
        {mgmt_listen_addr, "0.0.0.0"},
        {mgmt_listen_port, 50063},

        %% Upstream C++ yuzu-server address (GatewayUpstream service port)
        %% Server must be started with --gateway-upstream "addr:port" matching this.
        {upstream_addr, "127.0.0.1"},
        {upstream_port, 50055},

        %% Upstream connection pool size
        {upstream_pool_size, 32},

        %% Heartbeat batching interval (ms) — 1s gives ~0.5s avg latency
        {heartbeat_batch_interval_ms, 1000},

        %% Default command timeout (seconds)
        {default_command_timeout_s, 300},

        %% Prometheus metrics HTTP port
        {prometheus_port, 9568},

        %% Health/readiness HTTP port
        {health_port, 8081},

        %% Agent telemetry gauge emission interval (ms)
        {telemetry_gauge_interval_ms, 10000},

        %% Circuit breaker settings (upstream connection protection)
        {circuit_breaker_failure_threshold, 5},
        {circuit_breaker_reset_timeout_ms, 10000},
        {circuit_breaker_max_reset_timeout_ms, 300000},

        %% Stream backpressure threshold (message queue length)
        {backpressure_threshold, 1000},

        %% TLS master switch. Set to false to force plaintext even if certs
        %% are configured (useful for local testing). Default: auto (TLS used
        %% when tls config is present, plaintext otherwise).
        %% Override: YUZU_GW_TLS_ENABLED=false
        %% {tls_enabled, false},

        %% TLS configuration (optional — omit for plaintext)
        %% {tls, [
        %%     {certfile, "/etc/yuzu/gateway.crt"},
        %%     {keyfile,  "/etc/yuzu/gateway.key"},
        %%     {cacertfile, "/etc/yuzu/ca.crt"},
        %%     {verify, verify_peer},
        %%     {fail_if_no_peer_cert, true}
        %% ]},

        %% Consistent hash ring: virtual nodes per physical node
        {hash_ring_vnodes, 256}
    ]},

    {grpcbox, [
        {client, #{channels => [
            %% default_channel: upstream C++ yuzu-server (GatewayUpstream service)
            %% Port must match --gateway-upstream flag on the server.
            {default_channel, [{http, "127.0.0.1", 50055, []}], #{}}
        ]}},
        {servers, [
            %% Agent-facing service (agents connect here)
            #{grpc_opts => #{
                service_protos => [agent_pb],
                services => #{'yuzu.agent.v1.AgentService' => yuzu_gw_agent_service}
            },
            listen_opts => #{port => 50061, ip => {0,0,0,0}}},
            %% Operator-facing service (dashboard/CLI connects here)
            #{grpc_opts => #{
                service_protos => [management_pb],
                services => #{'yuzu.server.v1.ManagementService' => yuzu_gw_mgmt_service}
            },
            listen_opts => #{port => 50063, ip => {127,0,0,1}}}
        ]}
    ]},

    {kernel, [
        {connect_all, false},
        {net_ticktime, 30},
        {logger_level, info},
        {logger, [
            {handler, default, logger_std_h, #{
                level => info,
                formatter => {logger_formatter, #{
                    template => [time, " [", level, "] ", pid, " ", msg, "\n"]
                }}
            }}
        ]}
    ]}
].
