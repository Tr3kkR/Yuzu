{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 28, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_MANIFEST_MODE": "ON"
      }
    },
    {
      "name": "linux-debug",
      "displayName": "Linux x64 Debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux x64 Release",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_TARGET_TRIPLET": "x64-linux",
        "YUZU_ENABLE_LTO": "ON"
      }
    },
    {
      "name": "windows-debug",
      "displayName": "Windows x64 Debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDebugDLL"
      }
    },
    {
      "name": "windows-release",
      "displayName": "Windows x64 Release",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDLL",
        "YUZU_ENABLE_LTO": "ON"
      }
    },
    {
      "name": "macos-debug",
      "displayName": "macOS Debug (Apple Silicon / x64)",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "arm64-osx"
      }
    },
    {
      "name": "macos-release",
      "displayName": "macOS Release",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VCPKG_TARGET_TRIPLET": "arm64-osx",
        "YUZU_ENABLE_LTO": "ON"
      }
    },
    {
      "name": "arm64-linux-debug",
      "displayName": "Linux ARM64 Debug (cross-compile)",
      "inherits": "base",
      "toolchainFile": "${sourceDir}/cmake/toolchains/aarch64-linux-gnu.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VCPKG_TARGET_TRIPLET": "arm64-linux",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/aarch64-linux-gnu.cmake"
      }
    },
    {
      "name": "arm64-linux-release",
      "displayName": "Linux ARM64 Release (cross-compile)",
      "inherits": "arm64-linux-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "YUZU_ENABLE_LTO": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "linux-debug",        "configurePreset": "linux-debug" },
    { "name": "linux-release",      "configurePreset": "linux-release" },
    { "name": "windows-debug",      "configurePreset": "windows-debug" },
    { "name": "windows-release",    "configurePreset": "windows-release" },
    { "name": "macos-debug",        "configurePreset": "macos-debug" },
    { "name": "macos-release",      "configurePreset": "macos-release" },
    { "name": "arm64-linux-debug",  "configurePreset": "arm64-linux-debug" },
    { "name": "arm64-linux-release","configurePreset": "arm64-linux-release" }
  ],
  "testPresets": [
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug",
      "output": { "outputOnFailure": true },
      "execution": { "noTestsAction": "error", "stopOnFailure": true }
    }
  ]
}
