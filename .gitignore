# Build directories
# Convention: build-{linux,windows,macos} are the per-OS canonical dirs
# created by scripts/setup.sh. Legacy names are kept ignored for old checkouts.
build/
build-*/
builddir/
builddir-*/
clion-build/
cmake-build-*/
out/
.cache/

# Erlang / rebar3
gateway/_build/
gateway/.deps_cache/
gateway/ebin/
erl_crash.dump
*.beam

# Meson
.mesonpy/
meson-info/
meson-logs/
meson-private/
compile_commands.json

# vcpkg
vcpkg_installed/

# Binaries
*.exe
*.dll
*.so
*.so.*
*.dylib
*.a
*.lib
*.pdb
*.obj

# Generated protobuf sources
*.pb.h
*.pb.cc
*.grpc.pb.h
*.grpc.pb.cc

# IDE / Editor
.vscode/
.idea/
*.user
*.suo
.vs/
.clangd/
CLion.ini

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# UAT runtime state
.uat/
bash.exe.stackdump

# Dev artifacts
_build_tmp.bat
_debug_vcvars.bat
_vcvars_env.txt
build_now.bat
build_now.ps1
meson_stderr.txt
meson_stdout.txt
_build_err.txt
_build_out.txt
build_log.txt
.claude/settings.local.json
.uat-sanitizer/
*.local.md
docker-compose.local.yml
.codex
test_output.txt
test_xml.txt
update.finished
node_modules/
__pycache__/

# Test-binary symlinks created by scripts/link-tests.sh
# (per-component, per-triplet convenience links — see CLAUDE.md Test section)
/tests-build-*/

# /test pipeline scratch state (per-run RUN_ID directories)
# Persistent test-runs DB lives outside the repo at
# ~/.local/share/yuzu/test-runs.db — see .claude/skills/test/SKILL.md
/tests/.last-test-run/

# Future PR2 artifacts (coverage + sanitizer build dirs)
/build-linux-coverage/
/build-linux-asan/
/build-linux-tsan/
